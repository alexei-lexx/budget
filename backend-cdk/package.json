{
  "name": "backend-cdk",
  "version": "1.0.0",
  "bin": {
    "backend-cdk": "bin/backend-cdk.js"
  },
  "scripts": {
    "build": "dotenvx run -f .env.production --verbose -- tsc",
    "cdk": "dotenvx run -f .env.production --verbose -- cdk",
    "deploy": "dotenvx run -f .env.production --verbose -- cdk deploy --outputs-file cdk-outputs.json",
    "diff": "dotenvx run -f .env.production --verbose -- cdk diff",
    "synth": "dotenvx run -f .env.production --verbose -- cdk synth",
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "prettier:fix": "prettier --write .",
    "prettier": "prettier --check .",
    "test": "jest",
    "watch": "tsc -w"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.44.2",
    "@eslint/js": "^9.28.0",
    "@types/jest": "^29.5.14",
    "@types/node": "22.7.9",
    "aws-cdk": "^2.1016.1",
    "eslint": "^9.28.0",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.33.1"
  },
  "dependencies": {
    "aws-cdk-lib": "2.196.0",
    "constructs": "^10.0.0"
  }
}
