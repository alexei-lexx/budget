NODE_ENV=development

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy

# Auth0
# AUTH_AUDIENCE=https://personal-budget-tracker
# AUTH_CLAIM_NAMESPACE=https://personal-budget-tracker
# AUTH_ISSUER=https://<TENANT>.<REGION>.auth0.com

# Cognito
AUTH_CLAIM_NAMESPACE=https://personal-budget-tracker
AUTH_CLIENT_ID=<USER_POOL_CLIENT_ID>
AUTH_ISSUER=https://cognito-idp.<REGION>.amazonaws.com/<USER_POOL_ID>

# Database Configuration
DYNAMODB_ENDPOINT=http://localhost:8000

# Database Table Names
ACCOUNTS_TABLE_NAME=Accounts
CATEGORIES_TABLE_NAME=Categories
CHAT_MESSAGES_TABLE_NAME=ChatMessages
MIGRATIONS_TABLE_NAME=Migrations
TELEGRAM_BOTS_TABLE_NAME=TelegramBots
TRANSACTIONS_TABLE_NAME=Transactions
USERS_TABLE_NAME=Users

# AWS Bedrock AI Configuration
AWS_BEARER_TOKEN_BEDROCK=<your_bedrock_api_key> # Long-term API key
# AWS_BEDROCK_CONNECTION_TIMEOUT=5000
# AWS_BEDROCK_MAX_TOKENS=2000
# AWS_BEDROCK_MODEL_ID=openai.gpt-oss-120b-1:0
# AWS_BEDROCK_REQUEST_TIMEOUT=30000
# AWS_BEDROCK_TEMPERATURE=0.2

# Application Configuration
# CHAT_HISTORY_MAX_MESSAGES=20
# CHAT_MESSAGE_TTL_SECONDS=86400 # 24 hours in seconds
WEBHOOK_BASE_URL="http://localhost:4000"

# LangSmith Tracing
# LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=<your-langsmith-api-key>
# LANGSMITH_PROJECT=<your-langsmith-project>
