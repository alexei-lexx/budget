# Required for Jest on Node 24+
# Jest runs tests inside Node's VM sandbox, where dynamic import() is disabled by default.
# Some dependencies (e.g. AWS SDK v3) use dynamic import internally.
# Node 24 enforces this strictly and throws:
# ERR_VM_DYNAMIC_IMPORT_CALLBACK_MISSING_FLAG
# This flag enables ESM support inside the VM so tests don't crash.
NODE_OPTIONS=--experimental-vm-modules

NODE_ENV=test

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy

# Cognito
AUTH_CLAIM_NAMESPACE=https://personal-budget-tracker
AUTH_CLIENT_ID=client-1234567890
AUTH_ISSUER=https://identity-provider.example.com

# Database Configuration
DYNAMODB_ENDPOINT=http://localhost:8000

# Database Table Names
ACCOUNTS_TABLE_NAME=_test_Accounts
CATEGORIES_TABLE_NAME=_test_Categories
MIGRATIONS_TABLE_NAME=_test_Migrations
TELEGRAM_BOTS_TABLE_NAME=_test_TelegramBots
TRANSACTIONS_TABLE_NAME=_test_Transactions
USERS_TABLE_NAME=_test_Users

# AWS Bedrock AI Configuration
AWS_BEARER_TOKEN_BEDROCK=bedrock-1234567890 # Long-term API key
AWS_BEDROCK_MAX_TOKENS=2000
AWS_BEDROCK_MODEL_ID=openai.gpt-oss-120b-1:0
AWS_BEDROCK_TEMPERATURE=0.2
