{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:bundle:background-job": "esbuild src/lambdas/background-job.ts --bundle --platform=node --format=esm --external:@aws-sdk/* --outfile=dist/background-job-lambda.mjs --banner:js=\"$(cat src/lambdas/esm-banner.ts)\"",
    "build:bundle:migrate": "esbuild src/lambdas/migrate.ts --bundle --platform=node --format=esm --external:@aws-sdk/* --outfile=dist/migrate-lambda.mjs --banner:js=\"$(cat src/lambdas/esm-banner.ts)\"",
    "build:bundle:web": "esbuild src/lambdas/web.ts --bundle --platform=node --format=esm --external:@aws-sdk/* --outfile=dist/web-lambda.mjs --banner:js=\"$(cat src/lambdas/esm-banner.ts)\"",
    "build:bundle": "npm run build:bundle:web && npm run build:bundle:background-job && npm run build:bundle:migrate",
    "build:clean": "rm -rf dist",
    "build:schema": "mkdir -p dist/graphql && cp src/graphql/schema.graphql dist/graphql/",
    "build": "npm run codegen && npm run typecheck && npm run build:clean && npm run build:bundle && npm run build:schema",
    "codegen": "graphql-codegen --config codegen.ts",
    "db:create": "dotenvx run --verbose -- tsx src/scripts/create-tables.ts",
    "db:drop": "dotenvx run --verbose -- tsx src/scripts/drop-tables.ts",
    "db:recreate": "npm run db:drop && npm run db:create",
    "db:seed": "dotenvx run --verbose -- tsx src/scripts/seed-data.ts",
    "db:setup": "npm run db:start && sleep 1 && npm run db:create",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "dev": "npm run db:start && npm run codegen && dotenvx run --verbose -- nodemon --exec tsx src/dev.ts",
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "migrate": "dotenvx run --verbose -- tsx src/scripts/migrate.ts",
    "postinstall": "patch-package",
    "prettier:fix": "prettier --write .",
    "prettier": "prettier --check .",
    "test:coverage": "dotenvx run -f .env.test -- vitest run --project unit --project repositories --coverage",
    "test:db:create": "dotenvx run -f .env.test --verbose -- tsx src/scripts/create-tables.ts",
    "test:db:drop": "dotenvx run -f .env.test --verbose -- tsx src/scripts/drop-tables.ts",
    "test:db:recreate": "npm run test:db:drop && npm run test:db:create",
    "test:db:setup": "npm run db:start && sleep 1 && npm run test:db:create",
    "test:integration": "dotenvx run -f .env.test -- vitest run --project integration",
    "test:repositories": "dotenvx run -f .env.test -- vitest run --project repositories",
    "test:unit": "dotenvx run -f .env.test -- vitest run --project unit",
    "test:watch": "dotenvx run -f .env.test -- vitest --project unit --project repositories",
    "test": "dotenvx run -f .env.test -- vitest run --project unit --project repositories",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/aws-lambda": "^4.0.1",
    "@aws-sdk/client-bedrock-runtime": "^3.914.0",
    "@aws-sdk/client-dynamodb": "^3.1045.0",
    "@aws-sdk/client-lambda": "^3.1019.0",
    "@aws-sdk/client-ssm": "^3.1045.0",
    "@aws-sdk/lib-dynamodb": "^3.1045.0",
    "@langchain/aws": "^1.3.5",
    "@langchain/core": "^1.1.43",
    "@smithy/node-http-handler": "^4.5.1",
    "aws-xray-sdk-core": "^3.11.0",
    "dataloader": "^2.2.3",
    "graphql": "^16.11.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.2",
    "langchain": "^1.3.5",
    "mathjs": "^15.2.0",
    "ulidx": "^2.4.1",
    "validator": "^13.15.26",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.4",
    "@eslint/js": "^9.38.0",
    "@faker-js/faker": "^9.9.0",
    "@graphql-codegen/cli": "6.0.1",
    "@graphql-codegen/typescript": "5.0.2",
    "@graphql-codegen/typescript-resolvers": "5.1.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/aws-lambda": "^8.10.159",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mathjs": "^9.4.1",
    "@types/node": "^24.10.4",
    "@types/validator": "^13.15.10",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "0.25.11",
    "eslint": "^9.38.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "nodemon": "^3.1.10",
    "patch-package": "^8.0.1",
    "prettier": "3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^4.1.5"
  }
}
