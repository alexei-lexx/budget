{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "npm run compile && rm -rf dist && esbuild src/lambda.ts --bundle --platform=node --outfile=dist/lambda.js",
    "compile": "tsc",
    "db:setup": "npm run db:start && ts-node scripts/create-tables.ts",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "dev": "npm run db:start && dotenvx run -f .env.development --verbose -- nodemon --exec ts-node src/index.ts",
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "prettier:fix": "prettier --write .",
    "prettier": "prettier --check ."
  },
  "dependencies": {
    "@apollo/server": "^4.12.2",
    "@as-integrations/aws-lambda": "^3.1.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "@dotenvx/dotenvx": "^1.44.2",
    "@types/jsonwebtoken": "^9.0.10",
    "aws-xray-sdk-core": "^3.9.0",
    "graphql": "^16.11.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.15.29",
    "esbuild": "0.25.5",
    "eslint": "^9.28.0",
    "nodemon": "^3.1.10",
    "prettier": "3.5.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
