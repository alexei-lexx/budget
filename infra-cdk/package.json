{
  "name": "infra-cdk",
  "version": "1.0.0",
  "bin": {
    "infra-cdk": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "cdk": "cdk",
    "deploy:auth:dev": "dotenvx run --verbose -- cdk deploy AuthCdkStack --outputs-file cdk-outputs.auth.development.json",
    "deploy": "cdk deploy --all",
    "diff": "cdk diff",
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "prettier:fix": "prettier --write .",
    "prettier": "prettier --check .",
    "synth": "cdk synth",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "watch": "tsc -w"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@eslint/js": "^9.28.0",
    "@types/aws-lambda": "^8.10.160",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.4",
    "aws-cdk": "^2.1105.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.28.0",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.33.1"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.237.1",
    "constructs": "^10.4.5"
  }
}
