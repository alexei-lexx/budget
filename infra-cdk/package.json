{
  "name": "infra-cdk",
  "version": "1.0.0",
  "bin": {
    "infra-cdk": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "cdk": "cdk",
    "deploy:auth:dev": "dotenvx run --verbose -- cdk deploy AuthCdkStack --outputs-file cdk-outputs.auth.development.json",
    "deploy": "cdk deploy --all",
    "diff": "cdk diff",
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "prettier:fix": "prettier --write .",
    "prettier": "prettier --check .",
    "synth": "cdk synth",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "watch": "tsc -w"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "^25.2.3",
    "aws-cdk": "^2.1120.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.3.0",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1045.0",
    "aws-cdk-lib": "^2.253.1",
    "constructs": "^10.4.5"
  }
}
