{
  "name": "infra-cdk",
  "version": "1.0.0",
  "bin": {
    "infra-cdk": "bin/app.js"
  },
  "scripts": {
    "build": "dotenvx run -f .env.production --verbose -- tsc",
    "cdk": "dotenvx run -f .env.production --verbose -- cdk",
    "deploy:backend": "dotenvx run -f .env.production -- cdk deploy BackendCdkStack --outputs-file cdk-outputs.json",
    "deploy:frontend": "dotenvx run -f .env.production -- cdk deploy FrontendCdkStack --outputs-file cdk-outputs.json",
    "deploy": "dotenvx run -f .env.production --verbose -- cdk deploy --all --outputs-file cdk-outputs.json",
    "diff": "dotenvx run -f .env.production --verbose -- cdk diff",
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "prettier:fix": "prettier --write .",
    "prettier": "prettier --check .",
    "synth": "dotenvx run -f .env.production --verbose -- cdk synth",
    "test": "jest",
    "watch": "tsc -w"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.44.2",
    "@eslint/js": "^9.28.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.4",
    "aws-cdk": "^2.1016.1",
    "eslint": "^9.28.0",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.33.1"
  },
  "dependencies": {
    "aws-cdk-lib": "2.233.0",
    "constructs": "^10.0.0"
  }
}
