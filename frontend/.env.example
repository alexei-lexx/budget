VITE_GRAPHQL_ENDPOINT=http://localhost:4000/graphql

# Auth Configuration
VITE_AUTH_AUDIENCE=https://personal-budget-tracker
VITE_AUTH_CLIENT_ID=your-client-id-here
VITE_AUTH_DOMAIN=identity-provider.example.com
