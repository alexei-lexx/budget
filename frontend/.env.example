# GraphQL API endpoint
# Development default: http://localhost:4000/graphql
# Production default: /graphql (same-origin)
# Override for custom endpoints in any environment
VITE_GRAPHQL_ENDPOINT=http://localhost:4000/graphql

# Auth0 Configuration
# Auth0 domain (replace with your Auth0 domain)
VITE_AUTH0_DOMAIN=your-domain.us.auth0.com

# Auth0 client ID (replace with your Auth0 client ID)
VITE_AUTH0_CLIENT_ID=your-client-id-here

VITE_AUTH0_AUDIENCE=https://personal-budget-tracker
