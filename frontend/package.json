{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build-only": "vite build",
    "build": "npm run codegen && run-p typecheck \"build-only {@}\" --",
    "codegen:sync-schema": "cp ../backend/src/graphql/schema.graphql src/schema.graphql",
    "codegen": "npm run codegen:sync-schema && graphql-codegen",
    "dev": "npm run codegen && vite",
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "prettier:fix": "prettier --write .",
    "prettier": "prettier --check .",
    "preview": "vite preview",
    "test": "jest",
    "typecheck": "vue-tsc --build"
  },
  "dependencies": {
    "@apollo/client": "^3.14.0",
    "@vue/apollo-composable": "^4.2.2",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "oidc-client-ts": "^3.4.1",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3",
    "vuetify": "^3.10.7"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.0.1",
    "@graphql-codegen/typescript": "^5.0.2",
    "@graphql-codegen/typescript-operations": "^5.0.2",
    "@graphql-codegen/typescript-vue-apollo": "^5.0.0",
    "@mdi/font": "^7.4.47",
    "@tsconfig/node22": "^22.0.2",
    "@types/dom-speech-recognition": "^0.0.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.4",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.38.0",
    "eslint-plugin-vue": "~10.5.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.6.2",
    "sharp": "^0.34.5",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vue-tsc": "^3.1.1"
  }
}
